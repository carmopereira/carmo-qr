{
	"name": "carmo-qr",
	"version": "0.1.12",
	"description": "Interactive QR code generator block. Visitors enter a URL and get a downloadable SVG QR code with color theme support.",
	"author": "João Carmo Pereira",
	"license": "GPL-2.0-or-later",
	"main": "build/carmo-qr/index.js",
	"scripts": {
		"build": "wp-scripts build --webpack-copy-php --blocks-manifest --experimental-modules",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start --webpack-copy-php --blocks-manifest --experimental-modules",
		"prebuild": "npm version patch --no-git-tag-version && node scripts/sync-version.js",
		"updateGIT": "node scripts/update-git.js",
		"symlink": "node scripts/create-symlink.js"
	},
	"dependencies": {
		"@wordpress/block-editor": "latest",
		"@wordpress/blocks": "latest",
		"@wordpress/i18n": "latest",
		"qrcode-generator": "^2.0.4"
	},
	"devDependencies": {
		"@wordpress/scripts": "^31.4.0"
	}
}
